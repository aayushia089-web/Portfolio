<script>
const titles = [
  "☕ Java Developer",
  "🚀 Backend Developer",
  "🌱 Spring Boot Enthusiast",
  "💻 Frontend Developer",
  "🤖 AI/ML Explorer",
  "📚 DSA Enthusiast",
  "☁️ Future Software Engineer",
  "🎯 Problem Solver",
  "✨ Tech Enthusiast"
];

let i = 0, j = 0, deleting = false;

function typeEffect() {
  const el = document.getElementById("typing");
  const text = titles[i];

  if (!deleting) {
    el.textContent = text.substring(0, j++);
    if (j > text.length) {
      deleting = true;
      setTimeout(typeEffect, 1400);
      return;
    }
  } else {
    el.textContent = text.substring(0, j--);
    if (j < 0) {
      deleting = false;
      i = (i + 1) % titles.length;
    }
  }

  setTimeout(typeEffect, deleting ? 60 : 120);
}

typeEffect();
</script>

