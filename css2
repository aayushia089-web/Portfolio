  <title>Aayushi | Portfolio</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

  <style>
    :root{
      --primary:#ff5fa2;
      --secondary:#a855f7;
      --dark:#3f2b45;
      --text:#5f4a66;
      --glass:rgba(255,255,255,0.48);
      --border:rgba(255,255,255,0.45);
      --shadow:0 16px 40px rgba(120,70,140,.12);
    }

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      scroll-behavior:smooth;
    }

    body{
      font-family:'Poppins',sans-serif;
      color:var(--text);
      background:
        radial-gradient(circle at top left, rgba(255, 195, 225, 0.55), transparent 30%),
        radial-gradient(circle at bottom right, rgba(198, 164, 255, 0.45), transparent 35%),
        linear-gradient(135deg,#fff7fb,#fff0f7,#f6ecff);
      overflow-x:hidden;
    }

    body::before,
    body::after{
      content:"";
      position:fixed;
      border-radius:50%;
      filter:blur(20px);
      z-index:-1;
      opacity:.55;
      pointer-events:none;
    }

    body::before{
      width:420px;
      height:420px;
      background:radial-gradient(circle, rgba(255,167,208,.9), transparent 70%);
      top:-160px;
      left:-120px;
    }

    body::after{
      width:360px;
      height:360px;
      background:radial-gradient(circle, rgba(193,155,255,.9), transparent 70%);
      bottom:-120px;
      right:-100px;
    }

    nav{
      position:fixed;
      top:0;
      width:100%;
      padding:16px 8%;
      display:flex;
      justify-content:space-between;
      align-items:center;
      background:rgba(255,255,255,.45);
      backdrop-filter:blur(18px);
      border-bottom:1px solid rgba(255,255,255,.4);
      z-index:1000;
      box-shadow:0 6px 20px rgba(0,0,0,.04);
    }

    .logo{
      font-size:1.45rem;
      font-weight:800;
      background:linear-gradient(90deg,var(--primary),var(--secondary));
      -webkit-background-clip:text;
      background-clip:text;
      color:transparent;
    }

    nav ul{
      display:flex;
      list-style:none;
      gap:22px;
      flex-wrap:wrap;
    }

    nav ul a{
      text-decoration:none;
      font-weight:600;
      color:var(--dark);
      position:relative;
      transition:.3s ease;
    }

    nav ul a::after{
      content:"";
      position:absolute;
      left:0;
      bottom:-6px;
      width:0;
      height:2px;
      border-radius:999px;
      background:linear-gradient(90deg,var(--primary),var(--secondary));
      transition:.3s ease;
    }

    nav ul a:hover{
      color:var(--primary);
    }

    nav ul a:hover::after{
      width:100%;
    }

    section{
      padding:110px 10%;
    }

    .hero{
      min-height:100vh;
      display:flex;
      align-items:center;
      justify-content:center;
      text-align:center;
      flex-direction:column;
      position:relative;
    }

    .hero::before{
      content:"";
      position:absolute;
      inset:12% auto auto 50%;
      transform:translateX(-50%);
      width:min(860px, 90vw);
      height:540px;
      background:linear-gradient(135deg, rgba(255,255,255,.45), rgba(255,255,255,.18));
      border:1px solid rgba(255,255,255,.45);
      backdrop-filter:blur(20px);
      border-radius:32px;
      box-shadow:var(--shadow);
      z-index:-1;
    }

    .hero h1{
      font-size:clamp(3rem, 8vw, 5.6rem);
      line-height:1;
      margin-bottom:18px;
      font-weight:800;
      letter-spacing:-1px;
      background:linear-gradient(90deg,var(--primary),var(--secondary));
      -webkit-background-clip:text;
      background-clip:text;
      color:transparent;
    }

    .hero h2{
      font-size:1.35rem;
      font-weight:600;
      color:var(--dark);
      min-height:48px;
      margin-bottom:20px;
    }

    .hero p{
      max-width:820px;
      line-height:1.9;
      font-size:1.02rem;
      margin-bottom:30px;
    }

    .buttons{
      display:flex;
      gap:14px;
      flex-wrap:wrap;
      justify-content:center;
    }

    .btn{
      padding:14px 26px;
      border-radius:999px;
      text-decoration:none;
      font-weight:600;
      transition:.3s ease;
      border:1px solid transparent;
      box-shadow:0 10px 20px rgba(0,0,0,.05);
    }

    .btn-primary{
      background:linear-gradient(90deg,var(--primary),var(--secondary));
      color:#fff;
    }

    .btn-secondary{
      background:rgba(255,255,255,.72);
      color:var(--dark);
      border-color:rgba(170,120,200,.15);
    }

    .btn:hover{
      transform:translateY(-4px);
    }

    .title{
      text-align:center;
      font-size:clamp(2rem, 4vw, 2.6rem);
      margin-bottom:42px;
      color:var(--dark);
      font-weight:800;
      letter-spacing:-.5px;
    }

    .glass{
      background:var(--glass);
      backdrop-filter:blur(22px);
      border:1px solid var(--border);
      border-radius:28px;
      padding:32px;
      box-shadow:var(--shadow);
    }

    .grid{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(240px,1fr));
      gap:22px;
    }

    .card{
      background:rgba(255,255,255,.42);
      backdrop-filter:blur(16px);
      border:1px solid rgba(255,255,255,.4);
      padding:26px;
      border-radius:22px;
      box-shadow:0 10px 24px rgba(0,0,0,.05);
      transition:.35s ease;
      height:100%;
    }

    .card:hover{
      transform:translateY(-8px);
      box-shadow:0 18px 36px rgba(120,70,140,.12);
    }

    .card h3{
      margin-bottom:10px;
      color:var(--primary);
    }

    .card p{
      line-height:1.7;
    }

    .stats{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(170px,1fr));
      gap:18px;
      margin-top:30px;
    }

    .stat{
      text-align:center;
      padding:22px 18px;
      background:rgba(255,255,255,.48);
      border-radius:20px;
      border:1px solid rgba(255,255,255,.35);
    }

    .stat h3{
      font-size:2rem;
      color:var(--primary);
      margin-bottom:6px;
    }

    .timeline{
      position:relative;
      padding-left:28px;
      background:linear-gradient(var(--glass), var(--glass)) padding-box,
                 linear-gradient(180deg,var(--primary),var(--secondary)) border-box;
      border:1px solid transparent;
    }

    .timeline-item{
      position:relative;
      margin-bottom:22px;
      padding-left:4px;
    }

    .timeline-item::before{
      content:"";
      position:absolute;
      left:-38px;
      top:8px;
      width:14px;
      height:14px;
      border-radius:50%;
      background:linear-gradient(90deg,var(--primary),var(--secondary));
      box-shadow:0 0 0 6px rgba(255,95,162,.12);
    }

    .contact-grid{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
      gap:20px;
    }

    footer{
      padding:30px 20px;
      text-align:center;
      background:rgba(255,255,255,.42);
      backdrop-filter:blur(14px);
      margin-top:40px;
      border-top:1px solid rgba(255,255,255,.35);
      color:var(--dark);
    }

    @media(max-width:768px){
      nav{
        flex-direction:column;
        gap:10px;
        padding:14px 6%;
      }

      nav ul{
        justify-content:center;
        gap:14px;
      }

      section{
        padding:92px 6%;
      }

      .hero::before{
        height:560px;
      }

      .hero p{
        font-size:.98rem;
      }
    }
  </style>
</head>
